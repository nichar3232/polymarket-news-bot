# =============================================================================
# Polymarket Autonomous Trading Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# All free-tier or truly free APIs — no paid keys required.
# =============================================================================

# --- Polymarket CLOB (required for live/testnet trading) ---
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# --- LLM Providers (at least one required) ---
# Groq — primary (free, 14,400 req/day): https://console.groq.com
GROQ_API_KEY=

# Google Gemini — secondary (free, 1,500 req/day): https://aistudio.google.com
GEMINI_API_KEY=

# Ollama — local fallback (unlimited, must be running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- News APIs ---
# NewsAPI.org — free tier: https://newsapi.org
NEWSAPI_KEY=

# The Guardian — free: https://open-platform.theguardian.com
GUARDIAN_API_KEY=

# NY Times — free: https://developer.nytimes.com
NYTIMES_API_KEY=

# --- Reddit PRAW (free app credentials) ---
# Create app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polymarket-agent/0.1.0

# --- Redis (optional, has asyncio fallback) ---
REDIS_URL=redis://localhost:6379

# --- Trading Mode ---
# Set to "paper" for simulation, "testnet" for Amoy, "live" for real trading
TRADING_MODE=paper
POLYGON_TESTNET=true

# --- Risk Limits ---
MAX_POSITION_SIZE_USD=50
MAX_PORTFOLIO_EXPOSURE=0.25
MIN_EDGE_THRESHOLD=0.03
KELLY_FRACTION=0.25

# --- Agent Behavior ---
SIGNAL_REFRESH_SECONDS=60
LLM_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
